# Prism app-local configuration

# Optional public base URL for metadata and deploy previews
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional fallback used on hosted deployments
RENDER_EXTERNAL_URL=

# Optional local override for the Prism SQLite database path
PRISM_CODEX_DB_PATH=./data/prism-codex.db

# Shared secrets are usually sourced from the repo root .env
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EXA_API_KEY=
