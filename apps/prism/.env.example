# Prism app-local configuration

# Optional public base URL for metadata and deploy previews
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Use one privileged server key for Prism route handlers
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Shared secrets are usually sourced from the repo root .env
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EXA_API_KEY=
