CONVEX_URL=https://your-deployment.convex.cloud
PORT=4173

# Optional, only needed for Daily Digest generation in the Convex backend.
OPENAI_API_KEY=your-openai-api-key
READER_DIGEST_MODEL=gpt-4.1-mini
READER_DIGEST_TIMEZONE=America/Los_Angeles

# Optional, enables AgentMail newsletter ingestion into Reader.
AGENTMAIL_API_KEY=your-agentmail-api-key
READER_NEWSLETTER_INBOX_EMAIL=news@mj-kang.com

# Optional, only needed for the one-off feed importer from Supabase.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=your-secret-key
