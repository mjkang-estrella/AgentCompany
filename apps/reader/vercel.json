{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/articles/mark-all-read",
      "destination": "/api/mark-all-read"
    },
    {
      "source": "/api/articles/:id",
      "destination": "/api/article?id=:id"
    },
    {
      "source": "/api/feeds/:id/sync",
      "destination": "/api/feed-sync?id=:id"
    }
  ]
}
