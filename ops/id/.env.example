# 1Password account used by the agent.
OP_ACCOUNT_ADDRESS=my.1password.com
OP_ACCOUNT_EMAIL=ai@mj-kang.com
OP_ACCOUNT_SHORTHAND=agent-ai
OP_SECRET_KEY=
OP_ACCOUNT_PASSWORD=

# Dedicated vault for agent identity and runtime secrets.
OP_VAULT="Agent Identity"

# Agent login item stored in 1Password.
AGENT_EMAIL=ai@mj-kang.com
AGENT_LOGIN_TITLE=AgentMail
AGENT_LOGIN_URL=
AGENT_LOGIN_PASSWORD=

# Runtime secrets pulled from the repo root .env into a single 1Password item.
ROOT_ENV_SOURCE=../../.env
ROOT_ENV_ITEM_TITLE="Agent Runtime Secrets"
ROOT_ENV_KEYS=OPENAI_API_KEY,ANTHROPIC_API_KEY,OPENROUTER_API_KEY,GEMINI_API_KEY,EXA_API_KEY,AGENTMAIL_API_KEY,TWITTER_BEARER_TOKEN
