{
  "name": "agentcompany",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:prism": "npm run dev --workspace ./apps/prism",
    "dev:reader": "npm run dev --workspace ./apps/reader",
    "dev:inbox": "npm run dev --workspace ./apps/inbox",
    "wallet:status": "npm run status --workspace ./apps/wallet"
  }
}
